###############################################################################
# Immobil-IA local MVP
###############################################################################

# demo: al abrir la UI fuera de Tauri, usa datos visuales de src/lib/demoData.ts.
# real: al abrir la UI fuera de Tauri, inicia vacia. En Tauri siempre manda SQLite.
VITE_IMMOBILIA_DATA_MODE=real

# URL del Agente WS local. Tauri la usa para POST /scrape/:radarId.
IMMOBILIA_SCRAPER_AGENT_URL=http://localhost:8787

# Proveedor NLP autorizado para enviar al Agente WS durante la prueba.
# Valores previstos: none, gemini, openai, groq, together.
IMMOBILIA_NLP_PROVIDER=none

# Modelo usado cuando IMMOBILIA_NLP_PROVIDER=gemini.
GEMINI_MODEL=gemini-1.5-flash

###############################################################################
# Modelos locales ONNX
###############################################################################

# Opcional. Si queda vacio, Tauri busca automaticamente en models/.
IMMOBILIA_POST_COMPARER_MODEL_PATH=
IMMOBILIA_MATCHMAKER_MODEL_PATH=

###############################################################################
# Agente WS local
###############################################################################

PORT=8787

# mock: devuelve documentos simulados estructurados.
# live: ejecuta Puppeteer contra SCRAPER_SOURCE_URL o el fixture local controlado.
SCRAPER_MODE=mock

# puppeteer: usa SCRAPER_SOURCE_URL o fixture local.
# tavily: usa Tavily Search para descubrir resultados reales y normalizarlos localmente.
SCRAPER_DISCOVERY_PROVIDER=puppeteer

# Opcional. Si queda vacio, el Agente WS usa scraper-agent/fixtures/controlled-source.html.
# Puede ser file:///..., http://localhost/... o una URL externa controlada por ti.
SCRAPER_SOURCE_URL=

# Tavily discovery.
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=10
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
TAVILY_INCLUDE_DOMAINS=
TAVILY_EXCLUDE_DOMAINS=
TAVILY_EXTRA_QUERIES=
TAVILY_PORTAL_SEED_URLS=
TAVILY_ENABLE_SOCIAL_LEAD_SEARCH=true
TAVILY_SOCIAL_MAX_RESULTS=12
TAVILY_SOCIAL_SEARCH_DEPTH=basic
TAVILY_LEAD_SOURCE_DOMAINS=facebook.com,reddit.com,x.com,twitter.com,threads.net,instagram.com,tiktok.com,linkedin.com
TAVILY_SOCIAL_EXTRA_QUERIES=
TAVILY_SOCIAL_CRAWL_URLS=
TAVILY_ENABLE_PAGE_EXPANSION=true
TAVILY_EXPAND_SEED_LIMIT=8
TAVILY_EXTRACT_LIMIT=30
TAVILY_EXTRACT_DEPTH=basic
TAVILY_REQUEST_TIMEOUT_MS=90000
NLP_REQUEST_TIMEOUT_MS=90000
TAVILY_CRAWL_URLS=
TAVILY_CRAWL_LIMIT=5
TAVILY_CRAWL_MAX_DEPTH=1
TAVILY_CRAWL_INSTRUCTIONS=

###############################################################################
# Thin server / Postgres
###############################################################################

IMMOBILIA_ADMIN_API_URL=http://localhost:3000
IMMOBILIA_USER_ID=local-dev-user
IMMOBILIA_LICENSE_TOKEN=

THIN_SERVER_PORT=3000
POSTGRES_PORT=5432
POSTGRES_DB=immobilia
POSTGRES_USER=immobilia
POSTGRES_PASSWORD=immobilia_dev
DATABASE_URL=postgres://immobilia:immobilia_dev@localhost:5432/immobilia

###############################################################################
# Proxy broker
###############################################################################

# Si queda vacio, /proxy/token audita la solicitud y responde modo direct.
# Para Webshare, usa IMMOBILIA_PROXY_PROVIDER=webshare y WEBSHARE_API_KEY.
# Para proxy manual, usa IMMOBILIA_PROXY_PROVIDER=static y SERVER o HOST/PORT.
IMMOBILIA_PROXY_PROVIDER=static
IMMOBILIA_PROXY_SERVER=
IMMOBILIA_PROXY_HOST=
IMMOBILIA_PROXY_PORT=
IMMOBILIA_PROXY_PROTOCOL=http
IMMOBILIA_PROXY_USERNAME=
IMMOBILIA_PROXY_PASSWORD=
IMMOBILIA_PROXY_TTL_MINUTES=20

WEBSHARE_API_KEY=
WEBSHARE_PROXY_MODE=direct
WEBSHARE_PROXY_PROTOCOL=http
WEBSHARE_COUNTRY_CODES=
WEBSHARE_PAGE_SIZE=25

###############################################################################
# Proveedores externos futuros
###############################################################################

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
